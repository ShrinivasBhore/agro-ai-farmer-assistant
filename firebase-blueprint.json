{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Kisan Mitra app.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the user."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number of the user."
        },
        "name": {
          "type": "string",
          "description": "The name of the user."
        },
        "language": {
          "type": "string",
          "description": "The preferred language of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user profile was created."
        }
      },
      "required": ["uid", "phoneNumber", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    }
  }
}
